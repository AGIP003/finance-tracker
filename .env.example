# Example environment variables for project2
# Copy this to .env and fill with real secrets locally. DO NOT commit your real .env.

# App environment
FLASK_ENV=development            # development | production
SECRET_KEY=replace-with-a-secret-key

# Database (local connection pieces) - used when DB_USE_URL is False
DB_HOST=localhost
DB_PORT=5432
DB_NAME=finance_tracker
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_USE_URL=False                  # set to True if you want to use DATABASE_URL instead

# Optional single DATABASE_URL (postgres) - example format:
# postgres://user:password@host:5432/dbname
DATABASE_URL=

# Mail settings (for password reset emails)
MAIL_USERNAME=you@example.com
MAIL_APP_PASSWORD=your-app-password-or-api-key
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_DEFAULT_SENDER=you@example.com

# Frontend / CORS
FRONTEND_URL=http://localhost:5173
# Comma-separated list for CORS allowed origins (optional). In development local hosts are always allowed.
CORS_ORIGINS=http://localhost:5173,https://your-production-site.com

# Optional monitoring / feature flags
# EXAMPLE: SENTRY_DSN=
